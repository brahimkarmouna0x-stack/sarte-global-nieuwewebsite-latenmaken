# PocketBase backend URL (used server-side to fetch dynamic site settings).
# Not a secret — safe to expose; NEXT_PUBLIC_ keeps the door open for future client/realtime use.
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Shared secret for POST /api/revalidate-settings (on-demand footer refresh).
# Generate a long random value in production.
REVALIDATE_SECRET=change-me
